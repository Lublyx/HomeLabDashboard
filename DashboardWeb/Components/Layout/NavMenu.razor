@using DashboardWeb.Classes
<div class="top-row ps-3 navbar navbar-dark" style="background-color: @_color;">
    <div class="container-fluid">
        <a class="navbar-brand" href="">Dashboard</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler"/>

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Informations
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="ia">
                <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span> Home IA
            </NavLink>
        </div>

    </nav>
</div>

@code{
    private string _color = Developpement.IsDevelopment ? "#A80000" : "#0b0b0b";
}